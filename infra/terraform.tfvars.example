project_name = "hls-backend"
aws_region = "us-east-1"
environment = "prod"

vpc_cidr = "10.0.0.0/16"
public_subnet_cidr = "10.0.1.0/24"
private_subnet_cidr = "10.0.2.0/24"
availability_zone = "us-east-1a"

backend_instance_type = "t3.small"
frontend_instance_type = "t3.small"
# Leave empty to use latest Ubuntu 22.04 via AWS SSM.
# The deploy workflow SSHs as ubuntu and user_data uses apt-get.
ec2_ami_id = ""

cache_node_type = "cache.t3.micro"
cache_num_nodes = 1

s3_internal_bucket_name = "hls-backend-internal"
s3_assets_bucket_name = "hls-backend-assets-public"

ecr_repository_name = "hls-backend"

github_org = "my-org"
github_repo = "HLS-backend-base"
github_branch = "main"

# Backend application secrets
database_url              = "postgresql://postgres.[db_project_id]:[password]@aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres"
supabase_url              = "https://your-project.supabase.co"
supabase_service_role_key = "eyJhbGciOi..."
gemini_api_key            = "AIzaSy..."

# Example variable values — populated in task 10.2
