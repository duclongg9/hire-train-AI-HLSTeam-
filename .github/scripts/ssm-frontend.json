{
  "commands": [
    "aws ecr get-login-password --region us-east-1 | docker login --username AWS --password-stdin ${ECR_REGISTRY}",

    "docker pull ${ECR_REGISTRY}/${ECR_REPOSITORY_NAME}:frontend-latest",

    "docker stop hls-frontend || true",
    "docker rm hls-frontend || true",

    "docker run -d --name hls-frontend -p 80:3000 --restart always -e BACKEND_PRIVATE_URL=http://${BACKEND_PRIVATE_IP}:8000 ${ECR_REGISTRY}/${ECR_REPOSITORY_NAME}:frontend-latest"
]
}
