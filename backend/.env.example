# =============================================================================
# HireTrain AI — Backend Environment Variables
# Sao chép file này thành .env và điền giá trị thực tế.
# KHÔNG commit file .env lên Git.
# =============================================================================

# --- App ---
PROJECT_NAME="HireTrain AI"
DEBUG=False

# --- Database (AWS RDS PostgreSQL) ---
# Format: postgresql://username:password@host:port/dbname
DATABASE_URL=postgresql://hiretrain_user:your_password@your-rds-endpoint.rds.amazonaws.com:5432/hiretrain_db

# --- AWS ---
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET_NAME=hiretrain-cv-bucket

# --- AI Service ---
# TODO: AWS MIGRATION — GEMINI_API_KEY sẽ được thay bằng AWS Bedrock (không cần key riêng,
# dùng AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY ở trên thông qua boto3)
GEMINI_API_KEY=your_gemini_api_key

# Bật MOCK_MODE=true để chạy demo nội bộ không cần gọi AI thật (tiết kiệm chi phí)
MOCK_MODE=false

# --- SMTP (Email) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# --- CORS ---
# Danh sách origin cho phép, cách nhau bằng dấu phẩy
BACKEND_CORS_ORIGINS=["http://localhost:3000","https://yourdomain.com"]

# --- Feature Flags ---
ENABLE_VOICE_AI=True
